dataloader:
  _target_: openretina.data_io.hoefling_2024.dataloaders.natmov_dataloaders_v2
  _convert_: object
  batch_size: 128
  train_chunk_size: 50
  allow_over_boundaries: true
  validation_clip_indices:
  - 0
  - 4
  - 10
  - 11
  - 18
  - 30
